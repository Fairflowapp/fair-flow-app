rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    function signedIn() {
      return request.auth != null;
    }

    function uid() {
      return request.auth.uid;
    }

    function userDoc() {
      let doc = firestore.get(/databases/(default)/documents/users/$(uid()));
      return doc == null ? null : doc.data;
    }

    // User belongs to salon: users.salonId or salons/{salonId}/members/{uid}
    function belongsToSalon(salonId) {
      return signedIn() && (
        (userDoc() != null && userDoc().salonId == salonId)
        || firestore.exists(/databases/(default)/documents/salons/$(salonId)/members/$(uid()))
      );
    }

    // User private files
    match /users/{userId}/{allFiles=**} {
      allow read, write: if signedIn() && uid() == userId;
    }

    // Salon brand logo (only for users in that salon)
    match /salons/{salonId}/brand/{allFiles=**} {
      allow read: if signedIn();
      allow write: if signedIn() && userDoc() != null && userDoc().salonId == salonId;
    }

    // Staff documents: any signed-in user can read/write (tighten later: uid==staffId or same salon)
    match /salons/{salonId}/staff/{staffId}/{allPaths=**} {
      allow read, write: if signedIn();
    }

    // Inbox response documents (manager uploads response file for document requests)
    match /salons/{salonId}/inboxDocuments/{allPaths=**} {
      allow read, write: if signedIn() && userDoc() != null && userDoc().salonId == salonId;
    }

    // Media module: content work photos/videos (any signed-in user; app enforces salon)
    match /salons/{salonId}/media/{allPaths=**} {
      allow read, write: if signedIn();
    }

    // Training module: image block uploads (any signed-in user; app enforces salon)
    match /salons/{salonId}/training/images/{allPaths=**} {
      allow read, write: if signedIn();
    }

    // Training module: video block uploads (any signed-in user; app enforces salon)
    match /salons/{salonId}/training/videos/{allPaths=**} {
      allow read, write: if signedIn();
    }

    // deny everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
