rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    function signedIn() {
      return request.auth != null;
    }

    function uid() {
      return request.auth.uid;
    }

    function userDoc() {
      let doc = firestore.get(/databases/(default)/documents/users/$(uid()));
      return doc == null ? null : doc.data;
    }

    function userRoleLower() {
      return userDoc() != null && userDoc().role is string ? userDoc().role.lower() : '';
    }

    function isManagerSalonStorage(salonId) {
      return signedIn()
        && userDoc() != null
        && userDoc().salonId == salonId
        && userRoleLower() in ['manager', 'admin', 'owner'];
    }

    // User private files
    match /users/{userId}/{allFiles=**} {
      allow read, write: if signedIn() && uid() == userId;
    }

    // Salon brand logo (only for users in that salon)
    match /salons/{salonId}/brand/{allFiles=**} {
      allow read: if signedIn();
      allow write: if signedIn() && userDoc() != null && userDoc().salonId == salonId;
    }

    // Training module images (same salon as authenticated user)
    match /salons/{salonId}/training/{allPaths=**} {
      allow read: if signedIn() && userDoc() != null && userDoc().salonId == salonId;
      allow write: if signedIn() && userDoc() != null && userDoc().salonId == salonId;
    }

    // Staff documents: any signed-in user can read/write (tighten later: uid==staffId or same salon)
    match /salons/{salonId}/staff/{staffId}/{allPaths=**} {
      allow read, write: if signedIn();
    }

    // Inbox response documents (manager uploads response file for document requests)
    match /salons/{salonId}/inboxDocuments/{allPaths=**} {
      allow read, write: if signedIn() && userDoc() != null && userDoc().salonId == salonId;
    }

    // Inventory order receipts / invoices (managers upload; salon members read)
    match /salons/{salonId}/inventory-order-documents/{docId}/{fileName} {
      allow read: if signedIn() && userDoc() != null && userDoc().salonId == salonId;
      allow write: if isManagerSalonStorage(salonId);
    }

    // Per-order receipts (multiple files under each order). Loose rule: any signed-in user of the salon
    // can upload; if userDoc is missing (PIN sessions etc.), signedIn is enough (matches staff-docs pattern).
    match /salons/{salonId}/inventoryOrders/{orderId}/receipts/{receiptId}/{fileName} {
      allow read, write: if signedIn();
    }

    // Legacy Media uploads (contentWorks) — files under media/{workId}/...
    match /salons/{salonId}/media/{workId}/{allPaths=**} {
      allow read, write: if signedIn();
    }

    // Media module (work photos). Match staff/ path: many PIN flows have users/{uid} without salonId;
    // strict salon match caused storage/unauthorized when salonId in app ≠ Firestore user doc.
    match /salons/{salonId}/mediaWorks/{workId}/{allPaths=**} {
      allow read, write: if signedIn();
    }
    // Some clients / error URLs show lowercase path segment — allow same access
    match /salons/{salonId}/mediaworks/{workId}/{allPaths=**} {
      allow read, write: if signedIn();
    }

    // deny everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
