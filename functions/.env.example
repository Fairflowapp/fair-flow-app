# Copy to .env and fill in your values
# Gmail / Google Workspace: leave SMTP_HOST empty, use App Password
# Microsoft 365: SMTP_HOST=smtp.office365.com SMTP_PORT=587
# Other: SMTP_HOST=mail.yourdomain.com SMTP_PORT=587
SMTP_USER=support@fairflowapp.com
SMTP_PASS=your_app_password
# Optional for non-Gmail:
# SMTP_HOST=smtp.office365.com
# SMTP_PORT=587

# ---------------------------------------------------------------------------
# Stripe — Price IDs (test mode). Find these in Stripe Dashboard → Products.
# Each is a recurring monthly price attached to its product.
#   Base Plan ($99/mo)            — quantity is always 1
#   Additional Location ($79/mo)  — quantity = number of extra locations
#   Extra Storage ($10/mo)        — quantity = number of 10GB blocks
# ---------------------------------------------------------------------------
STRIPE_PRICE_BASE=price_...
STRIPE_PRICE_LOCATION=price_...
STRIPE_PRICE_STORAGE=price_...

# Stripe SECRETS — do NOT put these in .env. Set them via Secret Manager:
#   firebase functions:secrets:set STRIPE_SECRET_KEY     --project fairflowapp-db841
#   firebase functions:secrets:set STRIPE_WEBHOOK_SECRET --project fairflowapp-db841
