rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===== GLOBAL HELPER FUNCTIONS =====
    // Available to ALL match rules below

    function isSignedIn() {
      return request.auth != null;
    }

    function userDocData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function userExists() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function hasActiveMembership(salonId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid)/memberships/$(salonId))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)/memberships/$(salonId)).data.status == 'active';
    }

    function canAccessSalon(salonId) {
      return (userExists()
        && (
          userDocData().salonId == salonId
          || hasActiveMembership(salonId)
          || membershipStaffId(salonId) != ''
        ))
        || memberExists(salonId)
        || isStaffInSalon(salonId)
        // Multi-salon: client uses salons/{chosenSalonId}/... while users.salonId / members doc
        // may lag; membership subdoc supplies activeStaffIdForSalon — link staff row to auth uid.
        || (
          isSignedIn()
          && userExists()
          && activeStaffIdForSalon(salonId) != ''
          && staffDocUidMatches(salonId, activeStaffIdForSalon(salonId))
        );
    }

    function belongsToSalon(salonId) {
      return canAccessSalon(salonId);
    }

    /**
     * Whether the caller is allowed to write at a specific location within a
     * salon. Used for per-location documents whose docId equals the locationId
     * (e.g. queueState/{locationId}, tasksState/{locationId}).
     *
     * Allow cases (in precedence order):
     *   1. The doc is the shared "default" doc — used in single-location mode
     *      and as the legacy fallback for unstamped data; everyone can write.
     *   2. The caller is a manager/admin/owner at this salon — salon leadership
     *      can operate at any branch, matching existing client behavior.
     *   3. The caller has no linked staff profile (users/{uid}.staffId missing
     *      or blank) — legacy users created before the staff-link model existed.
     *   4. The caller's staff document has no allowedLocationIds field, or an
     *      empty list — legacy staff from before per-location assignments.
     *   5. The caller's allowedLocationIds list contains this location.
     *
     * Anything else is denied. This prevents a technician at Brickell from
     * writing to Key-Biscayne's queue or tasks state by crafting a request.
     */
    function userCanWriteAtLocation(salonId, locationId) {
      return locationId == 'default'
        || isManager(salonId)
        || activeStaffIdForSalon(salonId) == ''
        || !exists(/databases/$(database)/documents/salons/$(salonId)/staff/$(activeStaffIdForSalon(salonId)))
        || !(get(/databases/$(database)/documents/salons/$(salonId)/staff/$(activeStaffIdForSalon(salonId))).data.keys().hasAny(['allowedLocationIds']))
        || !(get(/databases/$(database)/documents/salons/$(salonId)/staff/$(activeStaffIdForSalon(salonId))).data.allowedLocationIds is list)
        || get(/databases/$(database)/documents/salons/$(salonId)/staff/$(activeStaffIdForSalon(salonId))).data.allowedLocationIds.size() == 0
        || get(/databases/$(database)/documents/salons/$(salonId)/staff/$(activeStaffIdForSalon(salonId))).data.allowedLocationIds.hasAny([locationId]);
    }

    /** salons/{salonId}/settings/main ownerUid: cannot change once set (except first claim to own uid). */
    function settingsMainOwnerUidUpdateAllowed() {
      return !request.resource.data.diff(resource.data).changedKeys().hasAny(['ownerUid'])
        || (
          !resource.data.keys().hasAny(['ownerUid'])
          && request.resource.data.ownerUid is string
          && request.resource.data.ownerUid == request.auth.uid
        );
    }

    // Normalize role comparisons (handles Admin/OWNER/etc)
    function userRole() {
      return (userDocData().role is string) ? userDocData().role.lower() : '';
    }

    function membershipRole(salonId) {
      return hasActiveMembership(salonId)
        && get(/databases/$(database)/documents/users/$(request.auth.uid)/memberships/$(salonId)).data.role is string
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)/memberships/$(salonId)).data.role.lower()
        : '';
    }

    /** Role on salons/{salonId}/members/{uid} — multi-salon / invite flows often omit users/{uid}.role */
    function memberDocRoleLower(salonId) {
      return memberExists(salonId)
        && memberDocData(salonId).role is string
        ? memberDocData(salonId).role.lower()
        : '';
    }

    function activeUserRoleForSalon(salonId) {
      return membershipRole(salonId) != '' ? membershipRole(salonId)
        : (memberDocRoleLower(salonId) != '' ? memberDocRoleLower(salonId) : userRole());
    }

    function isManager(salonId) {
      return belongsToSalon(salonId)
        && activeUserRoleForSalon(salonId) in ['manager', 'admin', 'owner'];
    }

    function isAdminOrOwner(salonId) {
      return belongsToSalon(salonId)
        && activeUserRoleForSalon(salonId) in ['admin', 'owner'];
    }

    function isOwner(salonId) {
      return belongsToSalon(salonId)
        && activeUserRoleForSalon(salonId) == 'owner';
    }

    /** True when this user is the salon doc ownerUid (covers multi-salon when member role is missing). */
    function isFirestoreSalonOwnerUid(salonId) {
      return isSignedIn()
        && salonId is string
        && exists(/databases/$(database)/documents/salons/$(salonId))
        && get(/databases/$(database)/documents/salons/$(salonId)).data.ownerUid == request.auth.uid;
    }

    /** Training library create/edit/delete: managers + salon ownerUid + assistant / front-desk roles */
    function canManageTrainingContent(salonId) {
      return isFirestoreSalonOwnerUid(salonId)
        || (
          belongsToSalon(salonId)
          && activeUserRoleForSalon(salonId) in [
            'manager',
            'admin',
            'owner',
            'assistant_manager',
            'assistant manager',
            'front_desk',
            'front desk'
          ]
        );
    }

    /** Ticket summary rows on close: same users doc roles the Tickets UI treats as staff/tech (not only manager/admin/owner). */
    function canCreateTicketSummary(salonId) {
      return belongsToSalon(salonId)
        && activeUserRoleForSalon(salonId) in ['manager', 'admin', 'owner', 'technician', 'tech', 'staff'];
    }

    function memberExists(salonId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/salons/$(salonId)/members/$(request.auth.uid));
    }

    function memberDocData(salonId) {
      return get(/databases/$(database)/documents/salons/$(salonId)/members/$(request.auth.uid)).data;
    }

    function matchesOwnStaffId(salonId, staffId) {
      return (
        userExists()
        && userDocData().staffId is string
        && userDocData().staffId == staffId
      ) || (
        activeStaffIdForSalon(salonId) != ''
        && activeStaffIdForSalon(salonId) == staffId
      ) || (
        memberExists(salonId)
        && memberDocData(salonId).staffId is string
        && memberDocData(salonId).staffId == staffId
      )
        // Invite / multi-tenant: staff row links to Auth via uid fields even when users.staffId lags
        || staffDocUidMatches(salonId, staffId);
    }

    /**
     * Member directory doc sometimes stores a truncated staffId prefix while queue/points stamps
     * the full salons/…/staff document id — strict equality denies pointsEvents:list. Allow only when
     * the prefix is long enough that accidental cross-account overlap is negligible and staff row exists.
     */
    function memberStaffPrefixMatchesStaffDocId(salonId, staffDocId) {
      return memberExists(salonId)
        && staffDocId is string
        && memberDocData(salonId).staffId is string
        && memberDocData(salonId).staffId.size() >= 14
        && staffDocId.size() >= memberDocData(salonId).staffId.size()
        && staffDocId.matches('^' + memberDocData(salonId).staffId + '.*');
    }

    /** users/{uid}.staffId sometimes stores a legacy prefix while queue/points stamp the real staff doc id. */
    function userStaffPrefixMatchesStaffDocId(staffDocId) {
      return userExists()
        && staffDocId is string
        && userDocData().staffId is string
        && userDocData().staffId.size() >= 14
        && staffDocId.size() >= userDocData().staffId.size()
        && staffDocId.matches('^' + userDocData().staffId + '.*');
    }

    /** users/{uid}/memberships/{salonId}.staffId can lag as a truncated id (mirrors member doc cases). */
    function membershipStaffPrefixMatchesStaffDocId(salonId, staffDocId) {
      return isSignedIn()
        && staffDocId is string
        && exists(/databases/$(database)/documents/users/$(request.auth.uid)/memberships/$(salonId))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)/memberships/$(salonId)).data.staffId is string
        && get(/databases/$(database)/documents/users/$(request.auth.uid)/memberships/$(salonId)).data.staffId.size() >= 14
        && staffDocId.size() >= get(/databases/$(database)/documents/users/$(request.auth.uid)/memberships/$(salonId)).data.staffId.size()
        && staffDocId.matches('^' + get(/databases/$(database)/documents/users/$(request.auth.uid)/memberships/$(salonId)).data.staffId + '.*');
    }

    function staffDocUidMatches(salonId, staffId) {
      return isSignedIn()
        && staffId is string
        && exists(/databases/$(database)/documents/salons/$(salonId)/staff/$(staffId))
        && (
          get(/databases/$(database)/documents/salons/$(salonId)/staff/$(staffId)).data.uid == request.auth.uid
          || get(/databases/$(database)/documents/salons/$(salonId)/staff/$(staffId)).data.firebaseUid == request.auth.uid
          || get(/databases/$(database)/documents/salons/$(salonId)/staff/$(staffId)).data.firebaseAuthUid == request.auth.uid
          ||           get(/databases/$(database)/documents/salons/$(salonId)/staff/$(staffId)).data.authUid == request.auth.uid
          || get(/databases/$(database)/documents/salons/$(salonId)/staff/$(staffId)).data.userUid == request.auth.uid
          || (
            request.auth.token.email is string
            && get(/databases/$(database)/documents/salons/$(salonId)/staff/$(staffId)).data.email is string
            && get(/databases/$(database)/documents/salons/$(salonId)/staff/$(staffId)).data.email.lower() == request.auth.token.email.lower()
          )
          || (
            memberExists(salonId)
            && memberDocData(salonId).staffId is string
            && memberDocData(salonId).staffId == staffId
          )
          // Staging: staff row sometimes lacks uid/email but users/{uid}.staffId already matches this doc id
          || (
            userExists()
            && userDocData().staffId is string
            && userDocData().staffId == staffId
          )
          || memberStaffPrefixMatchesStaffDocId(salonId, staffId)
          || userStaffPrefixMatchesStaffDocId(staffId)
          || membershipStaffPrefixMatchesStaffDocId(salonId, staffId)
        );
    }

    function canAccessAccountAsStaffOrMember(accountId) {
      return belongsToSalon(accountId) || memberExists(accountId) || isStaffInSalon(accountId);
    }

    /** My Profile (self): only these top-level fields may change on own staff doc */
    function staffSelfProfileChangedKeysAllowed() {
      return request.resource.data.diff(resource.data).changedKeys().hasOnly([
        'displayName',
        'phone',
        'photoUrl',
        'photoURL',
        'avatarUrl',
        'avatarUpdatedAtMs',
        'notifications',
        'pin',
        'birthday',
        'birthdayReminderSentForYear',
        'updatedAt',
        'lastActiveAt'
      ]);
    }

    function staffSelfProfileUpdateAllowed(salonId, staffId) {
      return matchesOwnStaffId(salonId, staffId)
        && (belongsToSalon(salonId) || isStaffInSalon(salonId))
        && staffSelfProfileChangedKeysAllowed();
    }

    /**
     * Invite finalize sets staff.uid = auth uid. If users.staffId is missing or wrong,
     * matchesOwnStaffId would deny — still allow lastActiveAt only on the row that lists this uid.
     */
    function staffLastActiveByStaffDocUid(salonId, staffId) {
      return belongsToSalon(salonId)
        && exists(/databases/$(database)/documents/salons/$(salonId)/staff/$(staffId))
        && get(/databases/$(database)/documents/salons/$(salonId)/staff/$(staffId)).data.uid == request.auth.uid
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['lastActiveAt']);
    }

    // Staff /documents delete: must match archived (UI writes lowercase; tolerate casing)
    function staffDocumentLifecycleIsArchived() {
      return resource.data.lifecycleStatus is string
        && resource.data.lifecycleStatus.lower() == 'archived';
    }

    // Training: staffId on /users/{uid} (set when technician uses PIN / profile)
    function userStaffId() {
      return userExists() && userDocData().keys().hasAll(['staffId'])
        ? userDocData().staffId
        : '';
    }

    /** staffId from users/{uid}/memberships/{salonId} whenever the doc exists (any status).
     *  hasActiveMembership() still requires status == active for stricter ops; staging often
     *  leaves status missing or non-active while staffId is already valid. */
    function membershipStaffId(salonId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid)/memberships/$(salonId))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)/memberships/$(salonId)).data.staffId is string
        && get(/databases/$(database)/documents/users/$(request.auth.uid)/memberships/$(salonId)).data.staffId != ''
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)/memberships/$(salonId)).data.staffId
        : '';
    }

    function memberStaffId(salonId) {
      return memberExists(salonId)
        && memberDocData(salonId).staffId is string
        ? memberDocData(salonId).staffId
        : '';
    }

    /** Prefer salon member doc staffId before legacy per-user memberships (multi-salon).
     *  Aligns with queue or PIN flows and Points events; fixes list rules tying events to activeStaffIdForSalon. */
    function activeStaffIdForSalon(salonId) {
      return memberStaffId(salonId) != ''
        ? memberStaffId(salonId)
        : (membershipStaffId(salonId) != '' ? membershipStaffId(salonId) : userStaffId());
    }

    // Staff doc on salon (for per-staff permissions.media_* on Media module)
    function salonStaffDocData(salonId, staffId) {
      return staffId != ''
        && exists(/databases/$(database)/documents/salons/$(salonId)/staff/$(staffId))
        ? get(/databases/$(database)/documents/salons/$(salonId)/staff/$(staffId)).data
        : null;
    }

    function mySalonStaffDocData(salonId) {
      return salonStaffDocData(salonId, activeStaffIdForSalon(salonId));
    }

    function legacyStaffMediaHandleFromDoc(d) {
      return d != null && (
        d.isAdmin == true
        || d.isManager == true
        || (
          d.role is string
          && d.role.lower() in ['manager', 'admin', 'owner', 'front_desk', 'assistant_manager']
        )
      );
    }

    function permMediaHandleAllowed(salonId) {
      return mySalonStaffDocData(salonId) != null && (
        (mySalonStaffDocData(salonId).permissions is map
          && mySalonStaffDocData(salonId).permissions.keys().hasAny(['media_handle']))
        ? mySalonStaffDocData(salonId).permissions.media_handle == true
        : legacyStaffMediaHandleFromDoc(mySalonStaffDocData(salonId))
      );
    }

    function permMediaUploadAllowed(salonId) {
      return mySalonStaffDocData(salonId) != null && (
        (mySalonStaffDocData(salonId).permissions is map
          && mySalonStaffDocData(salonId).permissions.keys().hasAny(['media_upload']))
        ? mySalonStaffDocData(salonId).permissions.media_upload == true
        : true
      );
    }

    /** Default is allow (mirrors UI `points_view_own !== false`); only explicit false denies. */
    function permPointsOwnAllowed(salonId) {
      return mySalonStaffDocData(salonId) != null && (
        !(mySalonStaffDocData(salonId).permissions is map)
        || !mySalonStaffDocData(salonId).permissions.keys().hasAny(['points_view_own'])
        || !(mySalonStaffDocData(salonId).permissions.points_view_own == false)
      );
    }

    function permPointsOwnAllowedForStaff(salonId, staffId) {
      return salonStaffDocData(salonId, staffId) != null && (
        !(salonStaffDocData(salonId, staffId).permissions is map)
        || !salonStaffDocData(salonId, staffId).permissions.keys().hasAny(['points_view_own'])
        || !(salonStaffDocData(salonId, staffId).permissions.points_view_own == false)
      );
    }

    /**
     * Minimal self read for pointsEvents when the event's staff row carries the caller's Auth uid.
     * Keeps access scoped to salons where the caller has a members/ doc or users/{uid}.salonId match.
     */
    function pointsEventsReadOwnByStaffUid(accountId) {
      return isSignedIn()
        && (memberExists(accountId) || (userExists() && userDocData().salonId == accountId))
        && resource.data.keys().hasAll(['staffId'])
        && resource.data.staffId is string
        && exists(/databases/$(database)/documents/salons/$(accountId)/staff/$(resource.data.staffId))
        && get(/databases/$(database)/documents/salons/$(accountId)/staff/$(resource.data.staffId)).data.uid == request.auth.uid
        && permPointsOwnAllowedForStaff(accountId, resource.data.staffId);
    }

    /**
     * Line staff reads accounts/{salon}/pointsEvents for their OWN staffId without requiring
     * resource.staffId == activeStaffIdForSalon(...). Membership docs can drift from the
     * salons/.../staff document id stamped on queued point events — Firestore would reject
     * list queries returning an empty-looking result set to the client unless this arm exists.
     */
    function canSignedInReadOwnPointsEvent(accountId) {
      return isSignedIn()
        && resource.data.keys().hasAll(['staffId'])
        && resource.data.staffId is string
        // Line staff may lack users.salonId / active membership while the pointsEvent + staff row still tie to auth (uid/email/prefix).
        && (
          belongsToSalon(accountId)
          || memberExists(accountId)
          || staffDocUidMatches(accountId, resource.data.staffId)
        )
        && (
          pointsEventsReadOwnByStaffUid(accountId)
          || (
            staffDocUidMatches(accountId, resource.data.staffId)
            && permPointsOwnAllowedForStaff(accountId, resource.data.staffId)
          )
          || (
            activeStaffIdForSalon(accountId) != ''
            && resource.data.staffId == activeStaffIdForSalon(accountId)
            && permPointsOwnAllowed(accountId)
          )
          // Exact match on salons/…/members/{authUid}.staffId (avoids edge cases in staffDocUidMatches paths).
          || (
            memberExists(accountId)
            && memberDocData(accountId).staffId is string
            && resource.data.staffId == memberDocData(accountId).staffId
            && permPointsOwnAllowedForStaff(accountId, resource.data.staffId)
          )
        );
    }

    function permPointsAllAllowed(salonId) {
      return isManager(salonId)
        || (
          mySalonStaffDocData(salonId) != null
          && mySalonStaffDocData(salonId).permissions is map
          && (
            mySalonStaffDocData(salonId).permissions.points_view_all == true
            || mySalonStaffDocData(salonId).permissions.points_manage == true
          )
        );
    }

    // Manage Fair Flow Points settings: staff.permissions.points_manage === true.
    // Used as the authoritative gate for writes on accounts/{accountId}/settings/points
    // and accounts/{accountId}/locations/{locationId}/settings/points.
    function permPointsManageAllowed(salonId) {
      return isAdminOrOwner(salonId)
        || (
          mySalonStaffDocData(salonId) != null
          && mySalonStaffDocData(salonId).permissions is map
          && mySalonStaffDocData(salonId).permissions.points_manage == true
        );
    }

    function permTimeClockManageAllowed(salonId) {
      return mySalonStaffDocData(salonId) != null
        && mySalonStaffDocData(salonId).permissions is map
        && mySalonStaffDocData(salonId).permissions.time_clock_manage == true;
    }

    // Legacy Media (contentWorks): PIN technicians may have staff doc but not users.salonId / members
    function isStaffInSalon(salonId) {
      return isSignedIn()
        && userExists()
        && userDocData().staffId is string
        && exists(/databases/$(database)/documents/salons/$(salonId)/staff/$(userDocData().staffId));
    }

    /** Salon access when users/{uid}.salonId / memberships are missing but members/{uid} or staff link exists. */
    function effectiveSalonMembership(salonId) {
      return belongsToSalon(salonId) || memberExists(salonId) || isStaffInSalon(salonId);
    }

    function canAccessMedia(salonId) {
      return belongsToSalon(salonId) || isStaffInSalon(salonId);
    }

    function trainingProgressIdentityUnchanged() {
      return request.resource.data.salonId == resource.data.salonId
        && request.resource.data.staffId == resource.data.staffId
        && request.resource.data.trainingId == resource.data.trainingId;
    }

    // ===== COLLECTIONS =====

    // Public GET for invite token docs (hashed doc id), only if unused + not expired
    match /staffInviteTokens/{inviteId} {
      allow get: if resource.data.usedAt == null
        && resource.data.expiresAt != null
        && request.time < resource.data.expiresAt;
      allow list: if false;
      allow create, update, delete: if false;
    }

    // User profile doc: each signed-in user can read/write ONLY their own doc
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      // Phase 1 memberships: additive, backward-compatible mirror of users/{uid}.salonId/staffId.
      // The app does not read this for routing yet. Client writes are limited
      // to a first-create mirror of the existing users/{uid} legacy fields.
      // Server Functions/Admin SDK bypass these rules for invite finalize and
      // future backfills.
      match /memberships/{salonId} {
        function managerMembershipCreateAllowed() {
          return isManager(salonId)
            && request.resource.data.salonId == salonId
            && request.resource.data.staffId is string
            && request.resource.data.role is string
            && request.resource.data.status in ['active', 'archived', 'pending']
            && request.resource.data.keys().hasOnly([
              'salonId',
              'staffId',
              'role',
              'status',
              'name',
              'email',
              'updatedAt'
            ]);
        }

        function managerMembershipUpdateAllowed() {
          return isManager(salonId)
            && request.resource.data.diff(resource.data).changedKeys().hasOnly([
              'staffId',
              'role',
              'status',
              'name',
              'email',
              'updatedAt'
            ])
            && (!request.resource.data.diff(resource.data).changedKeys().hasAny(['staffId']) || request.resource.data.staffId is string)
            && (!request.resource.data.diff(resource.data).changedKeys().hasAny(['role']) || request.resource.data.role is string)
            && (!request.resource.data.diff(resource.data).changedKeys().hasAny(['status']) || request.resource.data.status in ['active', 'archived', 'pending']);
        }

        allow read: if request.auth != null && request.auth.uid == uid;
        allow create: if managerMembershipCreateAllowed()
          || (
            request.auth != null
            && request.auth.uid == uid
            && exists(/databases/$(database)/documents/users/$(uid))
            && get(/databases/$(database)/documents/users/$(uid)).data.salonId == salonId
            && request.resource.data.salonId == salonId
            && request.resource.data.staffId is string
            && get(/databases/$(database)/documents/users/$(uid)).data.staffId is string
            && request.resource.data.staffId == get(/databases/$(database)/documents/users/$(uid)).data.staffId
            && request.resource.data.role is string
            && get(/databases/$(database)/documents/users/$(uid)).data.role is string
            && request.resource.data.role == get(/databases/$(database)/documents/users/$(uid)).data.role
            && request.resource.data.status in ['active', 'archived', 'pending']
          );
        allow update: if managerMembershipUpdateAllowed();
        allow delete: if false;
      }
    }

    // Salon members directory: minimal public profile (name, role, staffId) for "Send to" lookup
    // Each user writes their own; any salon member can read the whole list
    match /salons/{salonId}/members/{uid} {
      allow read: if belongsToSalon(salonId) || isStaffInSalon(salonId);
      allow create, update: if request.auth != null
        && request.auth.uid == uid
        && belongsToSalon(salonId)
        && request.resource.data.name is string
        && request.resource.data.role is string;
      allow delete: if false;
    }

    // Staff invite request: client writes here, Cloud Function triggers on create.
    match /staffInviteRequests/{requestId} {
      allow create: if request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && request.resource.data.createdByUid == request.auth.uid
        && request.resource.data.salonId is string
        && request.resource.data.email is string
        && request.resource.data.role is string
        && userRole() in ['owner', 'admin', 'manager']
        && userDocData().salonId == request.resource.data.salonId;
      allow read: if request.auth != null && resource.data.createdByUid == request.auth.uid;
      allow update, delete: if false;
    }

    // Basic salon doc: any signed-in user can read
    // CREATE: a signed-in user may create their own salon (owner sign-up / complete-setup flow)
    //   - must set themselves as ownerUid
    //   - must provide a non-empty name
    //   - and must NOT already have a users/{uid} profile pointing at another salon
    match /salons/{salonId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && (
          !exists(/databases/$(database)/documents/users/$(request.auth.uid))
          || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.salonId == null
          || !("salonId" in get(/databases/$(database)/documents/users/$(request.auth.uid)).data)
        );
      allow update, delete: if false;
    }

    // Stripe billing state — written by Cloud Functions (Admin SDK) only.
    // Owner can read so the Settings UI can show subscription status.
    match /salons/{salonId}/billing/{docId} {
      allow read: if isFirestoreSalonOwnerUid(salonId);
      allow write: if false;
    }

    // Stripe webhook idempotency markers — fully server-side.
    match /stripeWebhookEvents/{eventId} {
      allow read, write: if false;
    }

    match /settings/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Trampoline: triggers immediate invite processing
    match /processInviteNow/{docId} {
      allow create: if request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && userRole() in ['owner', 'admin', 'manager']
        && request.resource.data.requestId is string;
      allow read, update, delete: if false;
    }

    // Test email
    match /mail/{docId} {
      allow create: if request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && userRole() in ['owner', 'admin', 'manager']
        && request.resource.data.to is string
        && request.resource.data.message is map;
      allow read, update, delete: if false;
    }

    // Finalize invite request
    match /finalizeInviteRequests/{requestId} {
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.inviteToken is string;
      allow read: if request.auth != null && resource.data.uid == request.auth.uid;
      allow update, delete: if false;
    }

    // Custom Request Types - per-salon (Admin/Owner only)
    match /salons/{salonId}/requestTypes/{typeId} {
      allow read: if belongsToSalon(salonId);
      allow create, update, delete: if isAdminOrOwner(salonId);
    }

    // Technician Types - per-salon (Admin/Owner only)
    match /salons/{salonId}/technicianTypes/{technicianTypeId} {
      allow read: if belongsToSalon(salonId);
      allow create, update, delete: if isAdminOrOwner(salonId);
    }

    // Inbox visibility settings (which request types are hidden from staff)
    match /salons/{salonId}/inboxSettings/{docId} {
      allow read: if belongsToSalon(salonId);
      allow write: if isAdminOrOwner(salonId);
    }

    // Drafts for "Send to" flow: client writes, trigger resolves recipient and creates inboxItems (no CORS)
    match /salons/{salonId}/inboxRequestDrafts/{draftId} {
      allow create: if belongsToSalon(salonId)
        && isManager(salonId)
        && request.resource.data.createdByUid == request.auth.uid
        && request.resource.data.recipientStaffId is string
        && request.resource.data.requestDoc is map;
      allow read, update, delete: if false;
    }

    // ===== INBOX / REQUESTS SYSTEM =====
    match /salons/{salonId}/inboxItems/{itemId} {

      function changedKeys() {
        return request.resource.data.diff(resource.data).changedKeys();
      }

      /**
       * Inbox "To handle" in the UI also treats salon staff doc isManager/isAdmin/front_desk
       * as leadership. Staging / multi-salon often has users.role lagging while staff is correct;
       * without this, create + list queries fail with PERMISSION_DENIED while prod works.
       */
      function inboxManagerLike() {
        return isManager(salonId)
          || (
            belongsToSalon(salonId)
            && mySalonStaffDocData(salonId) != null
            && legacyStaffMediaHandleFromDoc(mySalonStaffDocData(salonId))
          );
      }

      /**
       * UI labels this "Service provider"; users/memberships may store technician, tech, staff,
       * service_provider, or "service provider" — isTechnician() only checked 'technician', which
       * blocked Inbox list + submit for most line staff on staging.
       */
      function inboxLineStaffLike() {
        let staff = mySalonStaffDocData(salonId);
        let sr = (staff != null && staff.role is string) ? staff.role.lower() : '';
        let r = activeUserRoleForSalon(salonId);
        return belongsToSalon(salonId)
          && !inboxManagerLike()
          && (
            r in ['technician', 'tech', 'staff', 'service_provider', 'service provider']
            || sr in ['technician', 'tech', 'staff', 'service_provider', 'service provider']
            || (
              r == ''
              && sr == ''
              && staff != null
              && !legacyStaffMediaHandleFromDoc(staff)
            )
          );
      }

      /**
       * Read/list: participant is always author or recipient — Firestore list filters match these.
       * Staging often has currentSalonId while users.salonId / memberships lag, so belongsToSalon(salonId)
       * is false even though docs here legitimately belong to the signed-in user (tenantId matches path).
       * Managers still need belongsToSalon + inboxManagerLike to scan the full queue.
       */
      function inboxParticipantSelfRead() {
        return isSignedIn()
          && userExists()
          && (
            resource.data.createdByUid == request.auth.uid
            || resource.data.forUid == request.auth.uid
          );
      }

      // inboxItems create: createdByRole may be string or (legacy staging) number.
      function inboxNewRequestDocFieldsValid() {
        return request.resource.data.tenantId == salonId
          && request.resource.data.type is string
          && request.resource.data.status in ['open', 'pending']
          && request.resource.data.priority is string
          && request.resource.data.createdByUid == request.auth.uid
          && request.resource.data.forUid is string
          && request.resource.data.createdByStaffId is string
          && request.resource.data.forStaffId is string
          && request.resource.data.createdByName is string
          // Staging seed data occasionally stored users.role as a number; client normalizes on write.
          && (
            request.resource.data.createdByRole is string
            || request.resource.data.createdByRole is int
            || request.resource.data.createdByRole is float
          )
          && request.resource.data.forStaffName is string
          && request.resource.data.decidedBy == null
          && request.resource.data.decidedAt == null
          && request.resource.data.managerNotes == null
          && request.resource.data.responseNote == null
          && request.resource.data.assignedTo == null
          && request.resource.data.needsInfoQuestion == null
          && request.resource.data.staffReply == null
          && request.resource.data.visibility == 'managers_only'
          && request.resource.data.unreadForManagers == true;
      }

      /**
       * Create: author must match an existing staff row for this salon (uid/email/member/users.staffId).
       * Do not additionally require permInboxSend / inboxLineStaffLike — staging often has flags or
       * activeStaffIdForSalon out of sync while the row is still legitimately theirs; managers keep
       * inboxManagerLike() without needing a linked staff doc id.
       */
      function inboxCreatorOwnsStaffRow(salonId) {
        return request.resource.data.createdByUid == request.auth.uid
          && staffDocUidMatches(salonId, request.resource.data.createdByStaffId);
      }

      // CREATE
      allow create: if inboxNewRequestDocFieldsValid()
        && (
          inboxManagerLike()
          || (isSignedIn() && inboxCreatorOwnsStaffRow(salonId))
        );

      // READ: participant may always read own rows (multi-salon / staging); managers need salon + role
      allow read: if inboxParticipantSelfRead()
        || (
          belongsToSalon(salonId)
          && (
            inboxManagerLike()
            || (inboxLineStaffLike() && (
              resource.data.createdByUid == request.auth.uid ||
              resource.data.forUid == request.auth.uid
            ))
          )
        );

      // UPDATE
      allow update: if belongsToSalon(salonId)
        && (
          // Automated system alerts (e.g. inventory_suggestion): managers can archive / annotate
          // them with a minimal set of status fields — bypasses full identity-equality checks because
          // these docs are created by the scanner and have no strict "author" constraints.
          (
            inboxManagerLike()
            && resource.data.type == 'inventory_suggestion'
            && changedKeys().hasOnly([
              'status',
              'decidedBy',
              'decidedAt',
              'lastActivityAt',
              'updatedAt',
              'unreadForManagers',
              'responseNote',
              'managerNotes'
            ])
          )
          ||
          // Managers: update management fields
          (
            inboxManagerLike()
            && request.resource.data.tenantId == resource.data.tenantId
            && request.resource.data.type == resource.data.type
            && request.resource.data.createdByUid == resource.data.createdByUid
            && request.resource.data.createdByStaffId == resource.data.createdByStaffId
            && request.resource.data.createdByName == resource.data.createdByName
            && request.resource.data.createdByRole == resource.data.createdByRole
            && request.resource.data.forUid == resource.data.forUid
            && request.resource.data.forStaffId == resource.data.forStaffId
            && request.resource.data.forStaffName == resource.data.forStaffName
            && request.resource.data.createdAt == resource.data.createdAt
            && request.resource.data.data == resource.data.data
            && changedKeys().hasOnly([
              'status',
              'assignedTo',
              'managerNotes',
              'responseNote',
              'needsInfoQuestion',
              'staffReply',
              'decidedBy',
              'decidedAt',
              'lastActivityAt',
              'updatedAt',
              'unreadForManagers',
              'priority',
              'staffDocumentId',
              'appliedToInventory',
              'appliedToInventoryAt',
              'appliedInventoryRefs'
            ])
          )
          ||
          // Manager: edit nested data (type / dates) before approve — only data + updatedAt may change
          // (Avoid field-by-field == on optional keys like staffDocumentId / decidedBy; those break when null vs missing.)
          (
            inboxManagerLike()
            && (resource.data.type == 'document_upload' || resource.data.type == 'document_request')
            && (resource.data.status == 'open' || resource.data.status == 'needs_info')
            && (
              changedKeys().hasOnly(['data', 'updatedAt'])
              || changedKeys().hasOnly(['data'])
              || changedKeys().hasOnly(['updatedAt'])
            )
          )
          ||
          // Any role: creator can reply when needs_info (membership / primary salon may lag staging)
          (
            userExists()
            && resource.data.createdByUid == request.auth.uid
            && resource.data.status == 'needs_info'
            && request.resource.data.tenantId == resource.data.tenantId
            && request.resource.data.type == resource.data.type
            && request.resource.data.createdByUid == resource.data.createdByUid
            && request.resource.data.forUid == resource.data.forUid
            && request.resource.data.createdAt == resource.data.createdAt
            && request.resource.data.data == resource.data.data
            && changedKeys().hasOnly([
              'staffReply',
              'status',
              'lastActivityAt',
              'updatedAt',
              'unreadForManagers'
            ])
          )
        );

      // DELETE — only when already archived (manager can permanently delete)
      allow delete: if belongsToSalon(salonId)
        && inboxManagerLike()
        && resource.data.status == 'archived';

      // Events subcollection (audit trail)
      match /events/{eventId} {
        allow read: if belongsToSalon(salonId)
          && (inboxManagerLike() || resource.data.forUid == request.auth.uid);
        allow write: if false;
      }
    }

    // ===== STAFF MEMBERS (cloud sync) =====
    // Manager/Admin/Owner: full CRUD. Salon members + PIN/staff linked via users.staffId: read (queue, schedule, etc.)
    match /salons/{salonId}/staff/{staffId} {
      allow read: if belongsToSalon(salonId) || isStaffInSalon(salonId)
        || (
          memberExists(salonId)
          && memberStaffId(salonId) == staffId
        )
        || staffDocUidMatches(salonId, staffId);
      allow create, delete: if belongsToSalon(salonId)
        && isManager(salonId);
      allow update: if (belongsToSalon(salonId) && isManager(salonId))
        || staffSelfProfileUpdateAllowed(salonId, staffId)
        || staffLastActiveByStaffDocUid(salonId, staffId);

      // Staff documents (Inbox approve → staff doc sync; Staff Member > Documents tab)
      match /documents/{documentId} {
        // Managers: any staff member's docs. Line staff: own row only — use matchesOwnStaffId /
        // staffDocUidMatches (not isTechnician + userStaffId), or "service provider" / multi-salon
        // staging breaks and approved Inbox uploads disappear from Staff Member > Documents.
        allow read: if (belongsToSalon(salonId) && isManager(salonId))
          || matchesOwnStaffId(salonId, staffId)
          || (
            memberExists(salonId)
            && memberStaffId(salonId) is string
            && memberStaffId(salonId) == staffId
          )
          || staffDocUidMatches(salonId, staffId);
        allow create, update: if belongsToSalon(salonId) && isManager(salonId);
        // Permanent delete (UI: archived docs only); client also enforces archived
        allow delete: if belongsToSalon(salonId) && isManager(salonId)
          && staffDocumentLifecycleIsArchived();
      }
    }

    // Staff presence (heartbeat + reception call popup via currentCall) — public/staff-call-cloud.js
    match /salons/{salonId}/staffPresence/{staffId} {
      allow read: if (
        belongsToSalon(salonId)
        && (
          isManager(salonId)
          || matchesOwnStaffId(salonId, staffId)
        )
      ) || (
        matchesOwnStaffId(salonId, staffId)
        && (
          effectiveSalonMembership(salonId)
          || staffDocUidMatches(salonId, staffId)
        )
      );
      allow create: if (
        belongsToSalon(salonId) && isManager(salonId)
      ) || (
        matchesOwnStaffId(salonId, staffId)
        && (
          effectiveSalonMembership(salonId)
          || staffDocUidMatches(salonId, staffId)
        )
        && request.resource.data.staffId == staffId
        && (
          request.resource.data.uid == null
          || request.resource.data.uid == request.auth.uid
        )
        && (
          request.resource.data.currentCall == null
          || request.resource.data.currentCall.status == 'accepted'
        )
      );
      allow update: if (
        belongsToSalon(salonId) && isManager(salonId)
      ) || (
        matchesOwnStaffId(salonId, staffId)
        && (
          effectiveSalonMembership(salonId)
          || staffDocUidMatches(salonId, staffId)
        )
        && request.resource.data.staffId == staffId
        && (
          request.resource.data.uid == null
          || request.resource.data.uid == request.auth.uid
          || request.resource.data.uid == resource.data.uid
        )
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          'staffId',
          'uid',
          'role',
          'name',
          'onlineStatus',
          'lastHeartbeatAt',
          'lastHeartbeatMs',
          'lastSeenAt',
          'lastActivityMs',
          'updatedAt',
          'inShift',
          'queueStatus',
          'currentCall'
        ])
        && (
          !request.resource.data.diff(resource.data).changedKeys().hasAny(['currentCall'])
          || (
            resource.data.currentCall is map
            && request.resource.data.currentCall is map
            && request.resource.data.currentCall.callId == resource.data.currentCall.callId
            && request.resource.data.currentCall.message == resource.data.currentCall.message
            && request.resource.data.currentCall.sentBy == resource.data.currentCall.sentBy
            && request.resource.data.currentCall.sentAt == resource.data.currentCall.sentAt
            && request.resource.data.currentCall.sentAtMs == resource.data.currentCall.sentAtMs
            && request.resource.data.currentCall.expiresAt == resource.data.currentCall.expiresAt
            && request.resource.data.currentCall.expiresAtMs == resource.data.currentCall.expiresAtMs
            && resource.data.currentCall.status == 'sent'
            && request.resource.data.currentCall.status == 'accepted'
          )
        )
      );
      allow delete: if belongsToSalon(salonId)
        && isManager(salonId);
    }

    // ===== CHAT / STRUCTURED MESSAGES SYSTEM =====

    // Chat Templates — Admin/Owner can CRUD; all salon members can read
    match /salons/{salonId}/chatTemplates/{templateId} {
      allow read: if belongsToSalon(salonId);
      allow create, update, delete: if isAdminOrOwner(salonId);
    }

    // Chat Flows — Admin/Owner can CRUD; all salon members can read
    match /salons/{salonId}/chatFlows/{flowId} {
      allow read: if belongsToSalon(salonId);
      allow create, update, delete: if isAdminOrOwner(salonId);
      match /steps/{stepId} {
        allow read: if belongsToSalon(salonId);
        allow create, update, delete: if isAdminOrOwner(salonId);
        match /options/{optionId} {
          allow read: if belongsToSalon(salonId);
          allow create, update, delete: if isAdminOrOwner(salonId);
        }
      }
    }

    // Conversations (PRIVATE) — only participants can read
    match /salons/{salonId}/conversations/{conversationId} {
      allow read: if belongsToSalon(salonId)
        && request.auth.uid in resource.data.participants;

      // Participant can create a 1:1 conversation doc
      allow create: if belongsToSalon(salonId)
        && request.resource.data.participants is list
        && request.resource.data.participants.size() == 2
        && request.auth.uid in request.resource.data.participants;

      // Participants can update summary/unread (participants list is immutable)
      allow update: if belongsToSalon(salonId)
        && request.auth.uid in resource.data.participants
        && request.resource.data.participants == resource.data.participants
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'lastMessageAt',
          'lastMessageAtMs',
          'lastTitle',
          'lastMessage',
          'lastSenderUid',
          'lastSenderName',
          'lastSenderRole',
          'unreadFor',
          'updatedAt',
          'updatedAtMs',
          'createdAt',
          'locationId'
        ]);

      allow delete: if false;

      match /messages/{messageId} {
        function isParticipant() {
          return belongsToSalon(salonId)
            && request.auth.uid in get(/databases/$(database)/documents/salons/$(salonId)/conversations/$(conversationId)).data.participants;
        }

        allow read: if isParticipant();
        allow create: if isParticipant()
          && request.resource.data.senderUid == request.auth.uid
          && request.resource.data.recipientUid is string
          && request.resource.data.readBy is list
          && (
            (request.resource.data.keys().hasAll(['templateId', 'title'])
             && request.resource.data.templateId is string
             && request.resource.data.title is string)
            || (request.resource.data.keys().hasAll(['flowId', 'flowTitle', 'renderedText'])
                && request.resource.data.flowId is string
                && request.resource.data.flowTitle is string
                && request.resource.data.renderedText is string)
            || (request.resource.data.keys().hasAll(['title', 'message'])
                && request.resource.data.title is string
                && request.resource.data.message is string)
          );

        // Allow updating only readBy field (mark as read)
        allow update: if isParticipant()
          && request.resource.data.diff(resource.data).changedKeys().hasOnly(['readBy']);

        allow delete: if false;
      }
    }

    // Chat Events (legacy) — restrict read to participants only
    match /salons/{salonId}/chatEvents/{eventId} {
      allow create: if belongsToSalon(salonId)
        && request.resource.data.senderUid == request.auth.uid
        && request.resource.data.title is string
        && request.resource.data.recipientUids is list;

      // Read only by sender or recipients
      allow read: if belongsToSalon(salonId)
        && (
          resource.data.senderUid == request.auth.uid
          || (resource.data.recipientUids is list && request.auth.uid in resource.data.recipientUids)
        );

      // Allow updating only readBy field (mark as read)
      allow update: if belongsToSalon(salonId)
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['readBy']);

      allow delete: if false;
    }

    // ===== TICKETS =====
    // Technicians: create + read their own
    // Manager/Admin/Owner: full read + update (close/archive) + delete
    match /salons/{salonId}/tickets/{ticketId} {
      allow read: if belongsToSalon(salonId);
      allow create: if belongsToSalon(salonId)
        && request.resource.data.createdByUid == request.auth.uid;
      allow update: if belongsToSalon(salonId)
        && (
          isManager(salonId)
          || resource.data.createdByUid == request.auth.uid
        );
      allow delete: if belongsToSalon(salonId)
        && isAdminOrOwner(salonId);
    }

    // Historical rows when a ticket is closed (Summary layer; not deleted when live ticket is removed)
    match /salons/{salonId}/ticketSummaries/{summaryId} {
      allow read: if belongsToSalon(salonId);
      allow create: if canCreateTicketSummary(salonId);
      // Admin/owner may set source-deleted markers when permanently deleting the live ticket (same role as ticket delete)
      allow update: if belongsToSalon(salonId) && isAdminOrOwner(salonId);
      allow delete: if false;
    }

    // ===== SERVICE CATALOG =====
    // All salon members can read; Manager/Admin/Owner can CRUD
    match /salons/{salonId}/services/{serviceId} {
      allow read: if belongsToSalon(salonId);
      allow create, update, delete: if isManager(salonId);
    }

    match /salons/{salonId}/serviceCategories/{catId} {
      allow read: if belongsToSalon(salonId);
      allow create, update, delete: if isManager(salonId);
    }

    // Account-level shared setup used by multi-location ticket service catalog.
    // accountId currently resolves to the salonId for this app, so reuse the
    // same salon membership helpers while keeping these paths account-scoped.
    match /accounts/{accountId}/shared/serviceCatalog {
      allow read: if belongsToSalon(accountId);
      allow create, update: if isManager(accountId);
      allow delete: if false;

      match /items/{serviceId} {
        allow read: if belongsToSalon(accountId);
        allow create, update, delete: if isManager(accountId);
      }
    }

    match /accounts/{accountId}/shared/serviceCategories {
      allow read: if belongsToSalon(accountId);
      allow create, update: if isManager(accountId);
      allow delete: if false;

      match /items/{categoryId} {
        allow read: if belongsToSalon(accountId);
        allow create, update, delete: if isManager(accountId);
      }
    }

    match /accounts/{accountId}/shared/taskTemplates {
      allow read: if belongsToSalon(accountId);
      allow create, update: if isManager(accountId);
      allow delete: if false;

      match /items/{taskId} {
        allow read: if belongsToSalon(accountId);
        allow create, update, delete: if isManager(accountId);
      }
    }

    match /accounts/{accountId}/shared/chatTemplates {
      allow read: if belongsToSalon(accountId);
      allow create, update: if isManager(accountId);
      allow delete: if false;

      match /items/{templateId} {
        allow read: if belongsToSalon(accountId);
        allow create, update, delete: if isManager(accountId);
      }
    }

    match /accounts/{accountId}/shared/chatFlows {
      allow read: if belongsToSalon(accountId);
      allow create, update: if isManager(accountId);
      allow delete: if false;

      match /items/{flowId} {
        allow read: if belongsToSalon(accountId);
        allow create, update, delete: if isManager(accountId);
      }
    }

    match /accounts/{accountId}/shared/inventoryCatalog {
      allow read: if belongsToSalon(accountId);
      allow create, update: if isManager(accountId);
      allow delete: if false;

      match /categories/{categoryId} {
        allow read: if belongsToSalon(accountId);
        allow create, update, delete: if isManager(accountId);

        match /subcategories/{subId} {
          allow read: if belongsToSalon(accountId);
          allow create, update, delete: if isManager(accountId);

          match /items/{itemId} {
            allow read: if belongsToSalon(accountId);
            allow create, update, delete: if isManager(accountId);
          }
        }
      }
    }

    match /accounts/{accountId}/settings/{settingId} {
      allow read: if settingId == "points" && isSignedIn();
      allow create, update: if settingId == "points"
        && permPointsManageAllowed(accountId);
      allow delete: if false;
    }

    match /accounts/{accountId}/pointsEvents/{eventId} {
      allow get: if permPointsAllAllowed(accountId)
        || isOwner(accountId)
        || canSignedInReadOwnPointsEvent(accountId);
      allow list: if permPointsAllAllowed(accountId)
        || isOwner(accountId)
        || (
          isSignedIn()
          && (
            belongsToSalon(accountId)
            || memberExists(accountId)
            || (userExists() && userDocData().salonId == accountId)
            || exists(/databases/$(database)/documents/users/$(request.auth.uid)/memberships/$(accountId))
          )
        );
      allow create: if (canAccessAccountAsStaffOrMember(accountId)
        || staffDocUidMatches(accountId, request.resource.data.staffId))
        && (
          (request.resource.data.type == "task_completed"
            && request.resource.data.sourceModule == "tasks")
          || (request.resource.data.type == "queue_join"
            && request.resource.data.sourceModule == "queue")
          || (request.resource.data.type == "media_upload"
            && request.resource.data.sourceModule == "media")
          || (request.resource.data.type == "ticket_upgrade"
            && request.resource.data.sourceModule == "tickets")
          || (request.resource.data.type == "points_correction"
            && request.resource.data.sourceModule == "points")
          || (
            request.resource.data.type == "manual_adjustment"
            && request.resource.data.sourceModule == "points_admin"
            && (isOwner(accountId) || permPointsManageAllowed(accountId))
            && request.resource.data.keys().hasAll(['sourceMeta'])
            && request.resource.data.keys().hasOnly([
              'staffId', 'staffName', 'locationId',
              'type', 'sourceModule', 'sourceId',
              'points', 'createdAt', 'weekKey', 'monthKey',
              'voided', 'sourceMeta'
            ])
            && request.resource.data.points is int
            && request.resource.data.points != 0
            && request.resource.data.points >= -100
            && request.resource.data.points <= 100
            && request.resource.data.voided == false
            && request.resource.data.sourceMeta is map
            && request.resource.data.sourceMeta.keys().hasAll(['reason'])
            && request.resource.data.sourceMeta.reason is string
            && request.resource.data.sourceMeta.reason.size() > 0
            && request.resource.data.sourceMeta.reason.size() <= 500
          )
        );
      allow update: if (isOwner(accountId) || permPointsManageAllowed(accountId))
        && resource.data.voided != true
        && request.resource.data.voided == true
        && request.resource.data.voidedReason is string;
      allow delete: if false;
    }

    match /accounts/{accountId}/staff/{staffId}/pointsSummary/{summaryId} {
      allow read: if summaryId == "main"
        || permPointsAllAllowed(accountId)
        || isOwner(accountId)
        || (
          summaryId == "main"
          && userExists()
          && userDocData().salonId == accountId
          && userDocData().staffId is string
          && userDocData().staffId == staffId
        )
        || (summaryId == "main" && matchesOwnStaffId(accountId, staffId) && permPointsOwnAllowed(accountId))
        || (summaryId == "main" && staffDocUidMatches(accountId, staffId) && permPointsOwnAllowedForStaff(accountId, staffId))
        // Rank visibility: when the account/branch has explicitly enabled
        // showRankToPrivate, any staff with own-points permission may read
        // every staff member's summary doc (totals only, no events) so the
        // client can compute their rank without revealing names. The flag
        // must be set on the account-level points settings doc.
        || (summaryId == "main"
          && permPointsOwnAllowed(accountId)
          && exists(/databases/$(database)/documents/accounts/$(accountId)/settings/points)
          && get(/databases/$(database)/documents/accounts/$(accountId)/settings/points).data.showRankToPrivate == true);
      allow create, update: if summaryId == "main"
        && (canAccessAccountAsStaffOrMember(accountId) || staffDocUidMatches(accountId, staffId));
      allow delete: if false;
    }

    match /accounts/{accountId}/locations/{locationId}/serviceOverrides/{serviceId} {
      allow read: if belongsToSalon(accountId);
      allow create, update, delete: if isManager(accountId);
    }

    match /accounts/{accountId}/locations/{locationId}/settings/{settingId} {
      allow read: if settingId == "points" && isSignedIn();
      allow create, update: if settingId == "points"
        && permPointsManageAllowed(accountId);
      allow delete: if false;
    }

    match /accounts/{accountId}/locations/{locationId}/inventoryState/{subId} {
      allow read: if belongsToSalon(accountId);
      allow create, update, delete: if isManager(accountId);
    }

    // ===== LOCATIONS =====
    // Physical salon branches / check-in points (name, address, lat/lng, allowed radius, active flag).
    // All salon members can read (needed for UI listings and check-in geofencing);
    // Manager/Admin/Owner can CRUD.
    match /salons/{salonId}/locations/{locationId} {
      allow read: if belongsToSalon(salonId);
      allow create, update, delete: if isManager(salonId);
    }

    // Inventory (categories, subcategories, flat inventoryItems master list)
    match /salons/{salonId}/inventoryCategories/{catId} {
      allow read: if belongsToSalon(salonId);
      allow create, update, delete: if isManager(salonId);
    }

    match /salons/{salonId}/inventoryCategories/{catId}/inventorySubcategories/{subId} {
      allow read: if belongsToSalon(salonId);
      allow create, update, delete: if isManager(salonId);
    }

    /** Draft / future workflow: inventory orders (UI saves drafts only for now). */
    match /salons/{salonId}/inventoryOrders/{orderId} {
      allow read: if belongsToSalon(salonId);
      allow create, update, delete: if isManager(salonId);
    }

    /** Active Create Order draft — one per salon (doc id = "active"). Persists in-progress work across refreshes. */
    match /salons/{salonId}/inventoryDrafts/{draftId} {
      allow read, write: if belongsToSalon(salonId) && isManager(salonId);
    }

    /** Receipts / invoices attached to an inventory order (multiple per order).
     *  Loose rule: any signed-in user can read/write (matches storage rule); UI is gated. */
    match /salons/{salonId}/inventoryOrders/{orderId}/receipts/{receiptId} {
      allow read, write: if request.auth != null;
    }

    match /salons/{salonId}/inventoryItems/{itemId} {
      allow read: if belongsToSalon(salonId);
      allow create, update, delete: if isManager(salonId);
    }

    // Inventory order receipts / invoices (Storage file + metadata; not tied to order entities yet)
    match /salons/{salonId}/inventoryOrderDocuments/{docId} {
      allow read: if belongsToSalon(salonId);
      allow create: if isManager(salonId)
        && request.resource.data.fileName is string
        && request.resource.data.fileUrl is string
        && request.resource.data.filePath is string
        && request.resource.data.uploadedBy == request.auth.uid;
      allow update, delete: if false;
    }

    // Weekly schedule publish flags (which ISO week-start dates are visible to all staff)
    match /salons/{salonId}/schedulePublish/{docId} {
      allow read: if belongsToSalon(salonId) || isStaffInSalon(salonId);
      allow create, update: if belongsToSalon(salonId) && isManager(salonId);
      allow delete: if false;
    }

    // Per-staff ping when their row changed after publish (manager triggers).
    // Doc id is either legacy `weekStart_staffId` (single-branch / pre-multi-location)
    // or per-location `locationId__weekStart_staffId` so each branch is isolated.
    match /salons/{salonId}/scheduleStaffChangePings/{pingId} {
      allow read: if belongsToSalon(salonId)
        && (
          isManager(salonId)
          || (
            userStaffId() != ''
            && resource.data.staffId == userStaffId()
          )
        );
      allow create, update: if belongsToSalon(salonId) && isManager(salonId)
        && request.resource.data.salonId == salonId
        && request.resource.data.weekStart is string
        && request.resource.data.staffId is string
        && request.resource.data.pingAt is timestamp
        && (
          pingId == request.resource.data.weekStart + '_' + request.resource.data.staffId
          || (
            request.resource.data.locationId is string
            && request.resource.data.locationId != ''
            && pingId == request.resource.data.locationId + '__' + request.resource.data.weekStart + '_' + request.resource.data.staffId
          )
        );
      allow delete: if false;
    }

    // Staff confirmed they viewed a published week.
    // Doc id is either legacy `weekStart_staffId` or per-location
    // `locationId__weekStart_staffId`.
    match /salons/{salonId}/scheduleWeekAcks/{ackId} {
      allow read: if belongsToSalon(salonId) || isStaffInSalon(salonId);
      allow create: if belongsToSalon(salonId)
        && userStaffId() != ''
        && request.resource.data.salonId == salonId
        && request.resource.data.weekStart is string
        && request.resource.data.staffId is string
        && request.resource.data.staffId == userStaffId()
        && request.resource.data.seenAt is timestamp
        && (
          ackId == request.resource.data.weekStart + '_' + request.resource.data.staffId
          || (
            request.resource.data.locationId is string
            && request.resource.data.locationId != ''
            && ackId == request.resource.data.locationId + '__' + request.resource.data.weekStart + '_' + request.resource.data.staffId
          )
        );
      allow update: if belongsToSalon(salonId)
        && userStaffId() != ''
        && resource.data.staffId == userStaffId()
        && request.resource.data.salonId == salonId
        && request.resource.data.weekStart == resource.data.weekStart
        && request.resource.data.staffId == resource.data.staffId
        && request.resource.data.seenAt is timestamp
        && (
          ackId == request.resource.data.weekStart + '_' + request.resource.data.staffId
          || (
            request.resource.data.locationId is string
            && request.resource.data.locationId != ''
            && ackId == request.resource.data.locationId + '__' + request.resource.data.weekStart + '_' + request.resource.data.staffId
          )
        );
      allow delete: if false;
    }

    // Per-staff training assignment toasts / inbox (APPS → Training); queried by forStaffId
    match /salons/{salonId}/staffNotifications/{notifId} {
      allow read: if (
        belongsToSalon(salonId)
        && (
          isManager(salonId)
          || (
            activeStaffIdForSalon(salonId) != ''
            && resource.data.forStaffId == activeStaffIdForSalon(salonId)
          )
          || (
            resource.data.forStaffId is string
            && staffDocUidMatches(salonId, resource.data.forStaffId)
          )
        )
      ) || (
        effectiveSalonMembership(salonId)
        && (
          (
            activeStaffIdForSalon(salonId) != ''
            && resource.data.forStaffId == activeStaffIdForSalon(salonId)
          )
          || (
            resource.data.forStaffId is string
            && staffDocUidMatches(salonId, resource.data.forStaffId)
          )
        )
      ) || (
        resource.data.forStaffId is string
        && staffDocUidMatches(salonId, resource.data.forStaffId)
      );
      allow create: if belongsToSalon(salonId) && isManager(salonId)
        && request.resource.data.forStaffId is string
        && request.resource.data.trainingId is string
        && request.resource.data.type == 'training_assigned';
      allow update: if (
        belongsToSalon(salonId)
        && (
          isManager(salonId)
          || (
            activeStaffIdForSalon(salonId) != ''
            && resource.data.forStaffId == activeStaffIdForSalon(salonId)
            && request.resource.data.forStaffId == resource.data.forStaffId
          )
          || (
            resource.data.forStaffId is string
            && request.resource.data.forStaffId == resource.data.forStaffId
            && staffDocUidMatches(salonId, resource.data.forStaffId)
          )
        )
      ) || (
        effectiveSalonMembership(salonId)
        && (
          (
            activeStaffIdForSalon(salonId) != ''
            && resource.data.forStaffId == activeStaffIdForSalon(salonId)
            && request.resource.data.forStaffId == resource.data.forStaffId
          )
          || (
            resource.data.forStaffId is string
            && request.resource.data.forStaffId == resource.data.forStaffId
            && staffDocUidMatches(salonId, resource.data.forStaffId)
          )
        )
      ) || (
        resource.data.forStaffId is string
        && request.resource.data.forStaffId == resource.data.forStaffId
        && staffDocUidMatches(salonId, resource.data.forStaffId)
      );
      allow delete: if belongsToSalon(salonId) && isManager(salonId);
    }

    // Media categories (labels for Media upload) — managers/admins OR staff with media_handle (same as To handle)
    match /salons/{salonId}/mediaCategories/{categoryId} {
      allow read: if canAccessMedia(salonId);
      allow create, update, delete: if canAccessMedia(salonId)
        && (isManager(salonId) || permMediaHandleAllowed(salonId));
    }

    // Legacy Media module (contentWorks, mediaItems, postedHistory)
    match /salons/{salonId}/contentWorks/{workId} {
      allow read: if canAccessMedia(salonId);
      allow create: if canAccessMedia(salonId)
        && request.resource.data.createdByUid == request.auth.uid
        && request.resource.data.salonId == salonId
        && request.resource.data.staffId is string
        && request.resource.data.staffName is string
        && request.resource.data.createdByRole is string
        && request.resource.data.status in ['active', 'archived', 'deleted'];
      allow update, delete: if canAccessMedia(salonId);

      match /mediaItems/{mediaId} {
        allow read: if canAccessMedia(salonId);
        allow create: if canAccessMedia(salonId)
          && request.resource.data.mediaType is string
          && request.resource.data.mediaUrl is string
          && request.resource.data.storagePath is string;
        allow update, delete: if canAccessMedia(salonId);
      }

      match /postedHistory/{historyId} {
        allow read: if canAccessMedia(salonId);
        allow create: if canAccessMedia(salonId)
          && request.resource.data.platform is string
          && request.resource.data.format is string
          && request.resource.data.postedDate is string
          && request.resource.data.markedByStaffId is string
          && request.resource.data.markedByName is string;
        allow update, delete: if canAccessMedia(salonId);
      }
    }

    // Salon media gallery (all uploads start pending → To handle for staff with media_handle)
    match /salons/{salonId}/mediaWorks/{workId} {
      allow read: if belongsToSalon(salonId);
      allow create: if belongsToSalon(salonId)
        && userStaffId() != ''
        && permMediaUploadAllowed(salonId)
        && request.resource.data.staffId == userStaffId()
        && request.resource.data.staffId is string
        && request.resource.data.layout in ['single', 'before_after']
        && request.resource.data.status == 'pending';
      allow update: if belongsToSalon(salonId) && (
        isManager(salonId)
        || permMediaHandleAllowed(salonId)
        || (
          userStaffId() != ''
          && resource.data.staffId == userStaffId()
          && resource.data.status == 'pending'
        )
      );
      allow delete: if belongsToSalon(salonId) && (
        isManager(salonId)
        || (
          permMediaHandleAllowed(salonId)
          && resource.data.status in ['approved', 'rejected']
        )
        || (
          userStaffId() != ''
          && resource.data.staffId == userStaffId()
          && resource.data.status == 'pending'
        )
      );
    }

    // ===== UI SETTINGS (historyRange, etc.) =====
    match /salons/{salonId}/settings/{docId} {
      allow read: if belongsToSalon(salonId);
      allow create: if belongsToSalon(salonId) && (
        docId != 'main'
        || !('ownerUid' in request.resource.data)
        || (
          request.resource.data.ownerUid is string
          && request.resource.data.ownerUid == request.auth.uid
        )
      );
      allow update: if belongsToSalon(salonId) && (
        docId != 'main'
        || settingsMainOwnerUidUpdateAllowed()
      );
      allow delete: if false;
    }

    // ===== QUEUE / TASKS STATE =====
    // docId encodes the locationId (or "default" for single-location mode).
    // Reads stay open to any salon member so staff can still see status at
    // any branch they navigate to, but writes are gated by userCanWriteAtLocation
    // so a technician at branch A cannot tamper with branch B's state.
    match /salons/{salonId}/queueState/{docId} {
      allow read: if belongsToSalon(salonId);
      allow write: if belongsToSalon(salonId)
        && userCanWriteAtLocation(salonId, docId);
    }

    match /salons/{salonId}/tasksState/{docId} {
      allow read: if belongsToSalon(salonId);
      allow write: if belongsToSalon(salonId)
        && userCanWriteAtLocation(salonId, docId);
    }

    // ===== TRAINING (root collections; each doc has salonId) =====
    match /trainingItems/{itemId} {
      allow read: if isSignedIn()
        && resource.data.salonId is string
        && canAccessSalon(resource.data.salonId);
      allow create: if userExists()
        && canAccessSalon(request.resource.data.salonId)
        && request.resource.data.salonId is string
        && request.resource.data.title is string
        && request.resource.data.category is string
        && canManageTrainingContent(request.resource.data.salonId);
      allow update: if userExists()
        && canAccessSalon(resource.data.salonId)
        && request.resource.data.salonId == resource.data.salonId
        && canManageTrainingContent(resource.data.salonId);
      allow delete: if userExists()
        && canAccessSalon(resource.data.salonId)
        && canManageTrainingContent(resource.data.salonId);
    }

    match /trainingProgress/{progressId} {
      allow read: if isSignedIn()
        && resource.data.salonId is string
        && canAccessSalon(resource.data.salonId)
        && (
          canManageTrainingContent(resource.data.salonId)
          || (activeStaffIdForSalon(resource.data.salonId) != ''
            && resource.data.staffId == activeStaffIdForSalon(resource.data.salonId))
        );
      allow create: if userExists()
        && canAccessSalon(request.resource.data.salonId)
        && request.resource.data.salonId is string
        && request.resource.data.staffId is string
        && request.resource.data.trainingId is string
        && request.resource.data.status is string
        && (
          canManageTrainingContent(request.resource.data.salonId)
          || (activeStaffIdForSalon(request.resource.data.salonId) != ''
            && request.resource.data.staffId == activeStaffIdForSalon(request.resource.data.salonId))
        );
      allow update: if userExists()
        && canAccessSalon(resource.data.salonId)
        && trainingProgressIdentityUnchanged()
        && (
          canManageTrainingContent(resource.data.salonId)
          || (activeStaffIdForSalon(resource.data.salonId) != ''
            && resource.data.staffId == activeStaffIdForSalon(resource.data.salonId))
        );
      allow delete: if false;
    }

    // ===== TIME CLOCK ENTRIES =====
    // salons/{salonId}/timeEntries/{entryId}
    //
    // Source of truth for ACTUAL worked time (not the schedule). An entry
    // records a clock-in/out pair for a staff member at a specific
    // location. Entries are decoupled from shifts — `linkedShiftId` is an
    // opaque string, never joined.
    //
    // Stage-1 permissions:
    //   - Read:   managers/admin/owner see everything; regular staff see
    //             only entries where resource.data.staffId matches their
    //             own staffId.
    //   - Create: managers/admin/owner can create for anyone; regular
    //             staff can create only for themselves. In both cases the
    //             entry must start as an OPEN, un-closed record to prevent
    //             a client from writing a back-dated "closed" entry past
    //             the manager-only update gate.
    //   - Update: managers/admin/owner only. Close / void / edit helpers
    //             will be added in a follow-up and will ride on this gate.
    //   - Delete: never. Invalidation uses status: "void" instead.
    match /salons/{salonId}/timeEntries/{entryId} {
      allow read: if belongsToSalon(salonId)
        && (
          isManager(salonId)
          || permTimeClockManageAllowed(salonId)
          || matchesOwnStaffId(salonId, resource.data.staffId)
        );

      allow create: if belongsToSalon(salonId)
        && request.resource.data.salonId == salonId
        && request.resource.data.locationId is string
        && request.resource.data.locationId != ''
        && request.resource.data.staffId is string
        && request.resource.data.staffId != ''
        && request.resource.data.status == 'open'
        && request.resource.data.clockOutAt == null
        && (
          isManager(salonId)
          || permTimeClockManageAllowed(salonId)
          || matchesOwnStaffId(salonId, request.resource.data.staffId)
        );

      allow update: if belongsToSalon(salonId)
        && (
          isManager(salonId)
          || permTimeClockManageAllowed(salonId)
          || (
            matchesOwnStaffId(salonId, resource.data.staffId)
            && resource.data.status == 'open'
            && request.resource.data.status == 'closed'
            && request.resource.data.salonId == resource.data.salonId
            && request.resource.data.locationId == resource.data.locationId
            && request.resource.data.staffId == resource.data.staffId
            && request.resource.data.clockInAt == resource.data.clockInAt
            && request.resource.data.clockOutAt != null
            && request.resource.data.durationMinutes is int
            && request.resource.data.updatedBy == request.auth.uid
            && request.resource.data.diff(resource.data).changedKeys().hasOnly([
              'status',
              'clockOutAt',
              'durationMinutes',
              'updatedAt',
              'updatedBy',
              'notes'
            ])
          )
        );

      allow delete: if false;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
