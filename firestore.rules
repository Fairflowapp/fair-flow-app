rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===== GLOBAL HELPER FUNCTIONS =====
    // Available to ALL match rules below

    function isSignedIn() {
      return request.auth != null;
    }

    function userDocData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function userExists() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function memberExists(salonId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/salons/$(salonId)/members/$(request.auth.uid));
    }

    function memberDocData(salonId) {
      return get(/databases/$(database)/documents/salons/$(salonId)/members/$(request.auth.uid)).data;
    }

    function belongsToSalon(salonId) {
      return isSignedIn()
        && (
          (userExists() && userDocData().salonId == salonId)
          || memberExists(salonId)
        );
    }

    // Normalize role comparisons (handles Admin/OWNER/etc)
    function userRole() {
      return (userDocData().role is string) ? userDocData().role.lower() : '';
    }

    function isManager(salonId) {
      return belongsToSalon(salonId)
        && userRole() in ['manager', 'admin', 'owner'];
    }

    function isTechnician(salonId) {
      return belongsToSalon(salonId)
        && userRole() == 'technician';
    }

    function isAdminOrOwner(salonId) {
      return belongsToSalon(salonId)
        && userRole() in ['admin', 'owner'];
    }

    function matchesOwnStaffId(salonId, staffId) {
      return (
        userExists()
        && userDocData().staffId is string
        && userDocData().staffId == staffId
      ) || (
        memberExists(salonId)
        && memberDocData(salonId).staffId is string
        && memberDocData(salonId).staffId == staffId
      );
    }

    // User is staff in salon (has staff doc) - for technicians who may lack users.salonId/members
    function isStaffInSalon(salonId) {
      return isSignedIn()
        && userExists()
        && userDocData().staffId is string
        && exists(/databases/$(database)/documents/salons/$(salonId)/staff/$(userDocData().staffId));
    }

    // ===== COLLECTIONS =====

    // Public GET for invite token docs (hashed doc id), only if unused + not expired
    match /staffInviteTokens/{inviteId} {
      allow get: if resource.data.usedAt == null
        && resource.data.expiresAt != null
        && request.time < resource.data.expiresAt;
      allow list: if false;
      allow create, update, delete: if false;
    }

    // User profile doc: each signed-in user can read/write ONLY their own doc
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Salon members directory: minimal public profile (name, role, staffId) for "Send to" lookup
    // Each user writes their own; any salon member can read the whole list
    match /salons/{salonId}/members/{uid} {
      allow read: if belongsToSalon(salonId);
      allow create, update: if request.auth != null
        && request.auth.uid == uid
        && belongsToSalon(salonId)
        && request.resource.data.name is string
        && request.resource.data.role is string;
      allow delete: if false;
    }

    // Staff invite request: client writes here, Cloud Function triggers on create.
    match /staffInviteRequests/{requestId} {
      allow create: if request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && request.resource.data.createdByUid == request.auth.uid
        && request.resource.data.salonId is string
        && request.resource.data.email is string
        && request.resource.data.role is string
        && userRole() in ['owner', 'admin', 'manager']
        && userDocData().salonId == request.resource.data.salonId;
      allow read: if request.auth != null && resource.data.createdByUid == request.auth.uid;
      allow update, delete: if false;
    }

    // Basic salon doc: any signed-in user can read
    match /salons/{salonId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /settings/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Trampoline: triggers immediate invite processing
    match /processInviteNow/{docId} {
      allow create: if request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && userRole() in ['owner', 'admin', 'manager']
        && request.resource.data.requestId is string;
      allow read, update, delete: if false;
    }

    // Test email
    match /mail/{docId} {
      allow create: if request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && userRole() in ['owner', 'admin', 'manager']
        && request.resource.data.to is string
        && request.resource.data.message is map;
      allow read, update, delete: if false;
    }

    // Finalize invite request
    match /finalizeInviteRequests/{requestId} {
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.inviteToken is string;
      allow read: if request.auth != null && resource.data.uid == request.auth.uid;
      allow update, delete: if false;
    }

    // Custom Request Types - per-salon (Admin/Owner only)
    match /salons/{salonId}/requestTypes/{typeId} {
      allow read: if belongsToSalon(salonId);
      allow create, update, delete: if isAdminOrOwner(salonId);
    }

    // Technician Types - per-salon (Admin/Owner only)
    match /salons/{salonId}/technicianTypes/{technicianTypeId} {
      allow read: if belongsToSalon(salonId);
      allow create, update, delete: if isAdminOrOwner(salonId);
    }

    // Inbox visibility settings (which request types are hidden from staff)
    match /salons/{salonId}/inboxSettings/{docId} {
      allow read: if belongsToSalon(salonId);
      allow write: if isAdminOrOwner(salonId);
    }

    // Drafts for "Send to" flow: client writes, trigger resolves recipient and creates inboxItems (no CORS)
    match /salons/{salonId}/inboxRequestDrafts/{draftId} {
      allow create: if belongsToSalon(salonId)
        && isManager(salonId)
        && request.resource.data.createdByUid == request.auth.uid
        && request.resource.data.recipientStaffId is string
        && request.resource.data.requestDoc is map;
      allow read, update, delete: if false;
    }

    // ===== INBOX / REQUESTS SYSTEM =====
    match /salons/{salonId}/inboxItems/{itemId} {

      function changedKeys() {
        return request.resource.data.diff(resource.data).changedKeys();
      }

      // CREATE
      allow create: if belongsToSalon(salonId)
        // Required fields
        && request.resource.data.tenantId == salonId
        && request.resource.data.type is string
        && request.resource.data.status == 'open'
        && request.resource.data.priority is string
        // Identity
        && request.resource.data.createdByUid == request.auth.uid
        && request.resource.data.forUid is string
        && request.resource.data.createdByStaffId is string
        && request.resource.data.forStaffId is string
        // Snapshots
        && request.resource.data.createdByName is string
        && request.resource.data.createdByRole is string
        && request.resource.data.forStaffName is string
        // Lock decision fields at creation
        && request.resource.data.decidedBy == null
        && request.resource.data.decidedAt == null
        && request.resource.data.managerNotes == null
        && request.resource.data.responseNote == null
        && request.resource.data.assignedTo == null
        && request.resource.data.needsInfoQuestion == null
        && request.resource.data.staffReply == null
        && request.resource.data.visibility == 'managers_only'
        && request.resource.data.unreadForManagers == true
        // Permission check: technician can create for self or directed to a manager; manager can create for anyone
        && (
          (isTechnician(salonId) && request.resource.data.createdByUid == request.auth.uid)
          || isManager(salonId)
        );

      // READ: manager sees all; technician sees requests they created OR are recipient of
      allow read: if belongsToSalon(salonId)
        && (
          isManager(salonId)
          || (isTechnician(salonId) && (
            resource.data.createdByUid == request.auth.uid ||
            resource.data.forUid == request.auth.uid
          ))
        );

      // UPDATE
      allow update: if belongsToSalon(salonId)
        && (
          // Managers: update management fields
          (
            isManager(salonId)
            && request.resource.data.tenantId == resource.data.tenantId
            && request.resource.data.type == resource.data.type
            && request.resource.data.createdByUid == resource.data.createdByUid
            && request.resource.data.createdByStaffId == resource.data.createdByStaffId
            && request.resource.data.createdByName == resource.data.createdByName
            && request.resource.data.createdByRole == resource.data.createdByRole
            && request.resource.data.forUid == resource.data.forUid
            && request.resource.data.forStaffId == resource.data.forStaffId
            && request.resource.data.forStaffName == resource.data.forStaffName
            && request.resource.data.createdAt == resource.data.createdAt
            && request.resource.data.data == resource.data.data
            && changedKeys().hasOnly([
              'status',
              'assignedTo',
              'managerNotes',
              'responseNote',
              'needsInfoQuestion',
              'staffReply',
              'decidedBy',
              'decidedAt',
              'lastActivityAt',
              'updatedAt',
              'unreadForManagers',
              'priority'
            ])
          )
          ||
          // Any role: creator can reply when needs_info
          (
            belongsToSalon(salonId)
            && resource.data.createdByUid == request.auth.uid
            && resource.data.status == 'needs_info'
            && request.resource.data.tenantId == resource.data.tenantId
            && request.resource.data.type == resource.data.type
            && request.resource.data.createdByUid == resource.data.createdByUid
            && request.resource.data.forUid == resource.data.forUid
            && request.resource.data.createdAt == resource.data.createdAt
            && request.resource.data.data == resource.data.data
            && changedKeys().hasOnly([
              'staffReply',
              'status',
              'lastActivityAt',
              'updatedAt',
              'unreadForManagers'
            ])
          )
        );

      // DELETE — only when already archived (manager can permanently delete)
      allow delete: if belongsToSalon(salonId)
        && isManager(salonId)
        && resource.data.status == 'archived';

      // Events subcollection (audit trail)
      match /events/{eventId} {
        allow read: if belongsToSalon(salonId)
          && (isManager(salonId) || resource.data.forUid == request.auth.uid);
        allow write: if false;
      }
    }

    // ===== STAFF MEMBERS (cloud sync) =====
    // Manager/Admin/Owner: full CRUD. All salon members: read (needed for queue/join flow)
    match /salons/{salonId}/staff/{staffId} {
      allow read: if belongsToSalon(salonId);
      allow create, update, delete: if belongsToSalon(salonId)
        && isManager(salonId);
    }

    // ===== STAFF PRESENCE / CALLS =====
    match /salons/{salonId}/staffPresence/{staffId} {
      allow read: if belongsToSalon(salonId)
        && (
          isManager(salonId)
          || matchesOwnStaffId(salonId, staffId)
        );
      allow create: if belongsToSalon(salonId)
        && (
          isManager(salonId)
          || (
            matchesOwnStaffId(salonId, staffId)
            && request.resource.data.staffId == staffId
            && (
              request.resource.data.uid == null
              || request.resource.data.uid == request.auth.uid
            )
            && (
              request.resource.data.currentCall == null
              || request.resource.data.currentCall.status == 'accepted'
            )
          )
        );
      allow update: if belongsToSalon(salonId)
        && (
          isManager(salonId)
          || (
            matchesOwnStaffId(salonId, staffId)
            && request.resource.data.staffId == staffId
            && (
              request.resource.data.uid == null
              || request.resource.data.uid == request.auth.uid
              || request.resource.data.uid == resource.data.uid
            )
            && request.resource.data.diff(resource.data).changedKeys().hasOnly([
              'staffId',
              'uid',
              'role',
              'name',
              'onlineStatus',
              'lastHeartbeatAt',
              'lastHeartbeatMs',
              'lastSeenAt',
              'lastActivityMs',
              'updatedAt',
              'inShift',
              'queueStatus',
              'currentCall'
            ])
            && (
              !request.resource.data.diff(resource.data).changedKeys().hasAny(['currentCall'])
              || (
                resource.data.currentCall is map
                && request.resource.data.currentCall is map
                && request.resource.data.currentCall.callId == resource.data.currentCall.callId
                && request.resource.data.currentCall.message == resource.data.currentCall.message
                && request.resource.data.currentCall.sentBy == resource.data.currentCall.sentBy
                && request.resource.data.currentCall.sentAt == resource.data.currentCall.sentAt
                && request.resource.data.currentCall.sentAtMs == resource.data.currentCall.sentAtMs
                && request.resource.data.currentCall.expiresAt == resource.data.currentCall.expiresAt
                && request.resource.data.currentCall.expiresAtMs == resource.data.currentCall.expiresAtMs
                && resource.data.currentCall.status == 'sent'
                && request.resource.data.currentCall.status == 'accepted'
              )
            )
          )
        );
      allow delete: if belongsToSalon(salonId)
        && isManager(salonId);
    }

    // ===== CHAT / STRUCTURED MESSAGES SYSTEM =====

    // Chat Templates — Admin/Owner can CRUD; all salon members can read
    match /salons/{salonId}/chatTemplates/{templateId} {
      allow read: if belongsToSalon(salonId);
      allow create, update, delete: if isAdminOrOwner(salonId);
    }

    // Chat Flows — Admin/Owner can CRUD; all salon members can read
    match /salons/{salonId}/chatFlows/{flowId} {
      allow read: if belongsToSalon(salonId);
      allow create, update, delete: if isAdminOrOwner(salonId);
      match /steps/{stepId} {
        allow read: if belongsToSalon(salonId);
        allow create, update, delete: if isAdminOrOwner(salonId);
        match /options/{optionId} {
          allow read: if belongsToSalon(salonId);
          allow create, update, delete: if isAdminOrOwner(salonId);
        }
      }
    }

    // Conversations (PRIVATE) — only participants can read
    match /salons/{salonId}/conversations/{conversationId} {
      allow read: if belongsToSalon(salonId)
        && request.auth.uid in resource.data.participants;

      // Participant can create a 1:1 conversation doc
      allow create: if belongsToSalon(salonId)
        && request.resource.data.participants is list
        && request.resource.data.participants.size() == 2
        && request.auth.uid in request.resource.data.participants;

      // Participants can update summary/unread (participants list is immutable)
      allow update: if belongsToSalon(salonId)
        && request.auth.uid in resource.data.participants
        && request.resource.data.participants == resource.data.participants
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          'lastMessageAt',
          'lastMessageAtMs',
          'lastTitle',
          'lastMessage',
          'lastSenderUid',
          'lastSenderName',
          'lastSenderRole',
          'unreadFor',
          'updatedAt',
          'updatedAtMs',
          'createdAt'
        ]);

      allow delete: if false;

      match /messages/{messageId} {
        function isParticipant() {
          return belongsToSalon(salonId)
            && request.auth.uid in get(/databases/$(database)/documents/salons/$(salonId)/conversations/$(conversationId)).data.participants;
        }

        allow read: if isParticipant();
        allow create: if isParticipant()
          && request.resource.data.senderUid == request.auth.uid
          && request.resource.data.recipientUid is string
          && request.resource.data.readBy is list
          && (
            (request.resource.data.keys().hasAll(['templateId', 'title'])
             && request.resource.data.templateId is string
             && request.resource.data.title is string)
            || (request.resource.data.keys().hasAll(['flowId', 'flowTitle', 'renderedText'])
                && request.resource.data.flowId is string
                && request.resource.data.flowTitle is string
                && request.resource.data.renderedText is string)
          );

        // Allow updating only readBy field (mark as read)
        allow update: if isParticipant()
          && request.resource.data.diff(resource.data).changedKeys().hasOnly(['readBy']);

        allow delete: if false;
      }
    }

    // Chat Events (legacy) — restrict read to participants only
    match /salons/{salonId}/chatEvents/{eventId} {
      allow create: if belongsToSalon(salonId)
        && request.resource.data.senderUid == request.auth.uid
        && request.resource.data.title is string
        && request.resource.data.recipientUids is list;

      // Read only by sender or recipients
      allow read: if belongsToSalon(salonId)
        && (
          resource.data.senderUid == request.auth.uid
          || (resource.data.recipientUids is list && request.auth.uid in resource.data.recipientUids)
        );

      // Allow updating only readBy field (mark as read)
      allow update: if belongsToSalon(salonId)
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['readBy']);

      allow delete: if false;
    }

    // ===== TICKETS =====
    // Technicians: create + read their own
    // Manager/Admin/Owner: full read + update (close/archive) + delete
    match /salons/{salonId}/tickets/{ticketId} {
      allow read: if belongsToSalon(salonId);
      allow create: if belongsToSalon(salonId)
        && request.resource.data.createdByUid == request.auth.uid;
      allow update: if belongsToSalon(salonId)
        && (
          isManager(salonId)
          || resource.data.createdByUid == request.auth.uid
        );
      allow delete: if belongsToSalon(salonId)
        && isAdminOrOwner(salonId);
    }

    // ===== SERVICE CATALOG =====
    // All salon members can read; Manager/Admin/Owner can CRUD
    match /salons/{salonId}/services/{serviceId} {
      allow read: if belongsToSalon(salonId);
      allow create, update, delete: if isManager(salonId);
    }

    match /salons/{salonId}/serviceCategories/{catId} {
      allow read: if belongsToSalon(salonId);
      allow create, update, delete: if isManager(salonId);
    }

    // ===== UI SETTINGS (historyRange, etc.) =====
    match /salons/{salonId}/settings/{docId} {
      allow read: if belongsToSalon(salonId);
      allow write: if belongsToSalon(salonId);
    }

    // ===== QUEUE / TASKS STATE =====
    match /salons/{salonId}/queueState/{docId} {
      allow read: if belongsToSalon(salonId);
      allow write: if belongsToSalon(salonId);
    }

    match /salons/{salonId}/tasksState/{docId} {
      allow read: if belongsToSalon(salonId);
      allow write: if belongsToSalon(salonId);
    }

    // Media Categories — per-salon (Admin/Manager can CRUD; all salon members can read)
    match /salons/{salonId}/mediaCategories/{categoryId} {
      allow read: if belongsToSalon(salonId) || isStaffInSalon(salonId);
      allow create, update, delete: if isManager(salonId);
    }

    // ===== MEDIA MODULE (content works, media items, posted history) =====
    // belongsToSalon OR isStaffInSalon - technicians may have staff doc but lack users.salonId/members
    function canAccessMedia(salonId) {
      return belongsToSalon(salonId) || isStaffInSalon(salonId);
    }
    match /salons/{salonId}/contentWorks/{workId} {
      allow read: if canAccessMedia(salonId);
      allow create: if canAccessMedia(salonId)
        && request.resource.data.createdByUid == request.auth.uid
        && request.resource.data.salonId == salonId
        && request.resource.data.staffId is string
        && request.resource.data.staffName is string
        && request.resource.data.createdByRole is string
        && request.resource.data.status in ['active', 'archived', 'deleted'];
      allow update, delete: if canAccessMedia(salonId);

      match /mediaItems/{mediaId} {
        allow read: if canAccessMedia(salonId);
        allow create: if canAccessMedia(salonId)
          && request.resource.data.mediaType is string
          && request.resource.data.mediaUrl is string
          && request.resource.data.storagePath is string;
        allow update, delete: if canAccessMedia(salonId);
      }

      match /postedHistory/{historyId} {
        allow read: if canAccessMedia(salonId);
        allow create: if canAccessMedia(salonId)
          && request.resource.data.platform is string
          && request.resource.data.format is string
          && request.resource.data.postedDate is string
          && request.resource.data.markedByStaffId is string
          && request.resource.data.markedByName is string;
        allow update, delete: if canAccessMedia(salonId);
      }
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
